# GoCode proxy (replaces direct Anthropic API)
GOCODE_BASE_URL=https://caas-gocode-prod.caas-prod.prod.onkatana.net
GOCODE_API_KEY=your_gocode_api_key_here

# Internal GitHub Enterprise
GITHUB_PAT=your_github_pat_here
GITHUB_API_URL=https://github.secureserver.net/api/v3

# Atlassian (personal token for prototype)
ATLASSIAN_BASE_URL=https://godaddy-corp.atlassian.net
ATLASSIAN_EMAIL=you@godaddy.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token_here

# Slack (optional, add in Day 2)
# Setup: api.slack.com/apps → Create app → Slash Commands → /certai
# Scopes: chat:write, im:write, commands
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_PORT=3002
# ngrok http 3002  →  set Request URL to https://<ngrok-url>/slack/events

# Web viewer base URL (used in Slack DM links)
WEB_BASE_URL=http://localhost:5173

# Server
PORT=3001
